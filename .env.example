# --- OpenAI (legacy — kept for fallback only, no longer the primary vision provider) ---
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_VISION_MODEL=gpt-4o

# --- Anthropic Claude (primary vision: detector + per-slab extractor) ---
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022

# --- CDN / Greysheet CPG API v2 ---
# Base URL from cpg-api-v2-documentation.md
CDN_BASE_URL=https://cpgpublicapiv2beta.greysheet.com
# Request these from CDN; both go into the X-ApiKey + X-Token headers.
CDN_API_KEY=
CDN_API_TOKEN=

# --- PCGS Public API (slab cert / barcode lookups) ---
# Base URL is fixed per PCGS docs. The token goes into Authorization: bearer <token>.
PCGS_API_BASE_URL=https://api.pcgs.com/publicapi
PCGS_API_TOKEN=

# --- Airtable ---
# Personal access token with data.records:read, data.records:write,
# schema.bases:read, schema.bases:write
AIRTABLE_TOKEN=pat_replace_me
AIRTABLE_BASE_ID=app_replace_me
AIRTABLE_SCANS_TABLE=Scans
AIRTABLE_SLABS_TABLE=Slabs

# --- App auth (single shared password for Ben) ---
APP_PASSWORD=change-me
# Session signing secret (any long random string, 32+ chars recommended)
SESSION_SECRET=please-change-this-to-a-long-random-string

# --- Optional: Vercel Blob for storing source photos ---
# BLOB_READ_WRITE_TOKEN=

# --- Vercel KV (durable scan-session store) ---
# Auto-injected by Vercel when you create a KV store and link it to the
# project. If both are missing the app falls back to an in-memory Map
# (fine for `next dev`, but on Vercel's serverless functions different
# requests can hit different lambda instances → review pages 404).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
